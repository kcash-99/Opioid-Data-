library(readxl)
library(dplyr)
library(tidyr)
library(writexl)

# ------------------------------------------------------------
# 1. Read your chronic absenteeism file
# ------------------------------------------------------------
file_path <- "#### file path ####"

df <- read_excel(file_path)

# Standardize column names
df <- df %>%
  rename(
    County = County,
    Chronic = `Chronically Absent`,
    Population = `School Population`,
    Percentage = Percentage
  )

