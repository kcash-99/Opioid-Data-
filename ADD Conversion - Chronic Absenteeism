# ------------------------------------------------------------
# 3. Merge your data with ADD lookup
# ------------------------------------------------------------

df_add <- df %>%
  left_join(add_lookup, by = "County")

# ------------------------------------------------------------
# 4. Aggregate chronic absenteeism up to ADD level
# ------------------------------------------------------------

add_summary <- df_add %>%
  group_by(ADD) %>%
  summarise(
    total_population = sum(Population, na.rm = TRUE),
    total_chronic_absent = sum(Chronic, na.rm = TRUE),
    chronic_absence_rate = total_chronic_absent / total_population
  ) %>%
  ungroup()

# ------------------------------------------------------------
# 5. Save to your folder
# ------------------------------------------------------------

output_path <- "#### file path #####"

write_xlsx(add_summary, output_path)

print(paste("File saved to:", output_path))
