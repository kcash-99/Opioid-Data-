for (sheet in sheets) {

  df <- dat_list[[sheet]] |> process_sheet()

  agg_list[[sheet]] <- df

  clean_name <- sheet |> str_replace_all(" ", "_")

  write_csv(df, file.path(save_path, paste0(clean_name, "_ADD_Weighted_SY2425.csv")))
}
