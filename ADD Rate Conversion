#------------------------------------------------------------
# 3. PROCESS FUNCTION â€” FIX COUNTY NAMES + WEIGHTED ADD RATES
#------------------------------------------------------------

process_sheet <- function(df) {

  df_clean <- df %>%
    rename(County = 1) %>%          # first column is County
    mutate(
      County = str_to_title(str_trim(County)),  # FIX: ADAIR â†’ Adair
      `Drug Incidents` = suppressWarnings(as.numeric(`Drug Incidents`)),
      Population       = suppressWarnings(as.numeric(Population))
    )

  # FIX special Mc* names
  df_clean$County <- df_clean$County %>%
    str_replace("^Mccracken$", "McCracken") %>%
    str_replace("^Mccreary$", "McCreary") %>%
    str_replace("^Mclean$", "McLean")

  df_add <- df_clean %>%
    left_join(add_lookup, by = "County")

  df_add %>%
    group_by(ADD) %>%
    summarize(
      ADD_Drug_Incidents = sum(`Drug Incidents`, na.rm = TRUE),
      ADD_Population     = sum(Population, na.rm = TRUE),
      ADD_Rate           = ADD_Drug_Incidents / ADD_Population,
      SchoolYear         = "SY24-25",
      .groups = "drop"
    )
}


#------------------------------------------------------------
# 4. APPLY TO ALL SHEETS AND SAVE
